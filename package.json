{
  "name": "cdfavorite",
  "version": "0.1.0",
  "description": "Change Directory Favorites: an interactive Bun CLI for jumping to saved directories.",
  "module": "src/index.tsx",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorovh/cdfavorite.git"
  },
  "keywords": [
    "bun",
    "cd",
    "cli",
    "directory",
    "favorites",
    "ink",
    "terminal"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "npm-dist",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "cdf-run": "./npm-dist/index.js",
    "cdf-setup": "./npm-dist/setup.js"
  },
  "scripts": {
    "build": "bun scripts/build-npm.ts",
    "cdf-run": "bun src/index.tsx",
    "cdf-setup": "bun src/setup.tsx",
    "postinstall": "bun scripts/postinstall.js",
    "prepublishOnly": "bun scripts/build-npm.ts",
    "pack:dry-run": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "biome:check": "biome check",
    "biome:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ink": "^7.0.3",
    "react": "^19.2.6"
  }
}
